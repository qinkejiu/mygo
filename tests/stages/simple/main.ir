module main
  ports:
    in  clk 1bu
    in  rst 1bu
  signals:
    const_0  const 1bu = true
    const_1  const 32bs = 1
    const_3  const 16bs = 2
    const_6  const 32bs = 0
    const_7  const 32bs = 0
    t0_2     wire  64bs
    t1_4     wire  64bs
    t2_5     wire  64bs
    varargs  reg   32bs
  process 0 main (stage=0, sequential)
    block entry
      t0_2 := convert(const_1)
      t1_4 := convert(const_3)
      t2_5 := t0_2 + t1_4
      print "The result is small: "%d(t2_5)"\n"
      return

